# Required
DATABASE_URL=sqlite:///./videos.db
CORS_ORIGINS=http://localhost:3000
BASE_URL=http://localhost:8000

# Optional authentication
AUTH_ENABLED=false
APP_PASSWORD=

# LLM provider for Download agentic navigation
# Options: ollama | openai | anthropic | openrouter | blank for auto-fallback
LLM_PROVIDER=ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:26b
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Translate feature
# faster_whisper runs locally. openai_whisper requires OPENAI_API_KEY.
TRANSCRIPTION_PROVIDER=faster_whisper
TRANSCRIPTION_MODEL=large-v3-turbo
TRANSLATE_LLM_PROVIDER=ollama

# Enhance feature
# setup.sh fills these automatically.
# Backend: auto | ncnn | python
REAL_ESRGAN_BACKEND=auto
REAL_ESRGAN_BIN=
REAL_ESRGAN_PYTHON=
REAL_ESRGAN_MODEL_PATH=

# Browser and storage
BROWSER_HEADLESS=true
PROXY_URLS=

# Optional path overrides. Leave commented unless you need custom locations.
# BROWSER_PROFILE_DIR=backend/app/browser_profile
# TEMP_STORAGE_DIR=backend/temp_storage
